<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <!-- ============ KARTA 1: Zdroj dat (TUDU) ============ -->
            <LinearLayout
                android:id="@+id/card1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/header1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▾ 1. TUDU · Výhybka"
                    android:textColor="@color/primary_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <!-- Náhledový obdélníček – výběr TUDU / výhybky klepnutím -->
                <LinearLayout
                    android:id="@+id/summary1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/summary_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <LinearLayout
                        android:id="@+id/colSummaryTudu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:padding="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TUDU"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvSummaryTudu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/primary_dark"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="#90CAF9"/>

                    <LinearLayout
                        android:id="@+id/colSummaryVyhybka"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:padding="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Výhybka"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvSummaryVyhybka"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/primary_dark"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="#90CAF9"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Část"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvSummaryCast"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/primary_dark"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/body1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickSource"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Vybrat soubor (.csv / .sql)"/>

                    <TextView
                        android:id="@+id/tvSourceFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:text="Žádný soubor"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Nápověda k části výhybky – mimo kartu 1, bílý obdélník jako karta 1 -->
            <LinearLayout
                android:id="@+id/castHintBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_bg"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvCastHintAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/primary_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/cast_part_bg"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:id="@+id/tvCastHintPart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/accent"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Vyjížděcí panel: pokročilé (EPC náhled, karty 2–5) -->
    <LinearLayout
        android:id="@+id/workflowSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_bg"
        android:elevation="20dp"
        android:orientation="vertical"
        app:behavior_hideable="false"
        app:behavior_peekHeight="56dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <LinearLayout
            android:id="@+id/workflowSheetHandle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="8dp">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_marginBottom="6dp"
                android:background="#B0BEC5"/>

            <TextView
                android:id="@+id/tvWorkflowSheetTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/workflow_sheet_title"
                android:textColor="@color/primary_dark"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/workflowSheetContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <include layout="@layout/bottom_sheet_workflow"/>

        </FrameLayout>

    </LinearLayout>

    <!-- Poslední záznam nad spodním panelem -->
    <LinearLayout
        android:id="@+id/lastRecordBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="64dp"
        android:background="@drawable/card_bg"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/last_record_label"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/summary_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <TextView
                android:id="@+id/tvLastRecordVyhybka"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/primary_dark"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <View
                android:layout_width="1dp"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="#90CAF9"/>

            <TextView
                android:id="@+id/tvLastRecordCast"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/primary_dark"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Ztmavení pod horní lištou při velké notifikaci -->
    <View
        android:id="@+id/scanDoneScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:clickable="true"
        android:elevation="34dp"
        android:focusable="true"
        android:visibility="gone"/>

    <!-- Hlavička + indikátor kroků – zůstávají čitelné při notifikaci -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg"
        android:elevation="40dp"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/ivAppLogo"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:src="@drawable/app_logo_header"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvReaderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="…"
                android:textColor="@color/text_muted"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stepIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/step1Circle"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/step_circle_pending"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp"
                    android:text="TUDU"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>
            </LinearLayout>

            <View
                android:layout_width="16dp"
                android:layout_height="2dp"
                android:layout_gravity="center_vertical"
                android:background="#D0D5DC"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/step2Circle"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/step_circle_pending"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp"
                    android:text="Načtení"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>
            </LinearLayout>

            <View
                android:layout_width="16dp"
                android:layout_height="2dp"
                android:layout_gravity="center_vertical"
                android:background="#D0D5DC"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/step3Circle"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/step_circle_pending"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/step3Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp"
                    android:text="Hotovo"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Karta velké notifikace po úspěšném načtení a zamčení tagu -->
    <LinearLayout
        android:id="@+id/scanDoneDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/card_bg"
        android:clickable="true"
        android:elevation="48dp"
        android:focusable="true"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvScanDoneTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/scan_done_title"
            android:textColor="@color/primary_dark"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/summary_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvScanDoneVyhybka"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/primary_dark"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/summary_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvScanDoneCast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/primary_dark"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanDoneContinue"
            style="@style/Widget.RfidGo.ActionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/primary"
            android:text="@string/scan_done_continue"
            android:textColor="#FFFFFF"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanDoneRetry"
            style="@style/Widget.RfidGo.ActionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/err"
            android:text="@string/scan_done_retry"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
