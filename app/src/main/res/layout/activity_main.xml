<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Hlavička -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name"
                    android:textColor="@color/text"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvReaderStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Čtečka: …"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Indikátor kroků -->
            <LinearLayout
                android:id="@+id/stepIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/step1Circle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/step_circle_pending"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:text="TUDU"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"/>
                </LinearLayout>

                <View
                    android:layout_width="16dp"
                    android:layout_height="2dp"
                    android:layout_gravity="center_vertical"
                    android:background="#D0D5DC"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/step2Circle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/step_circle_pending"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:text="EPC"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"/>
                </LinearLayout>

                <View
                    android:layout_width="16dp"
                    android:layout_height="2dp"
                    android:layout_gravity="center_vertical"
                    android:background="#D0D5DC"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/step3Circle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/step_circle_pending"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:text="Heslo"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"/>
                </LinearLayout>

                <View
                    android:layout_width="16dp"
                    android:layout_height="2dp"
                    android:layout_gravity="center_vertical"
                    android:background="#D0D5DC"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/step4Circle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/step_circle_pending"
                        android:gravity="center"
                        android:text="4"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:text="Lock"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ============ KARTA 1: Zdroj dat (TUDU) ============ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/header1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▾ 1. Zdroj dat – výběr TUDU"
                    android:textColor="@color/primary_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <!-- Náhledový obdélníček – výběr TUDU / výhybky klepnutím -->
                <LinearLayout
                    android:id="@+id/summary1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/summary_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <LinearLayout
                        android:id="@+id/colSummaryTudu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:padding="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TUDU"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvSummaryTudu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/primary_dark"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="#90CAF9"/>

                    <LinearLayout
                        android:id="@+id/colSummaryVyhybka"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:padding="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Výhybka"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvSummaryVyhybka"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/primary_dark"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="#90CAF9"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Část"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvSummaryCast"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/primary_dark"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/body1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickSource"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Vybrat soubor (.csv / .sql)"/>

                    <TextView
                        android:id="@+id/tvSourceFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:text="Žádný soubor"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:text="TUDU:"
                        android:textColor="@color/text"
                        android:textStyle="bold"/>
                    <Spinner
                        android:id="@+id/spTudu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="8dp"
                        android:text="Výhybka:"
                        android:textColor="@color/text"
                        android:textStyle="bold"/>
                    <Spinner
                        android:id="@+id/spVyhybka"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvVyhybkaInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="6dp"
                        android:text=""
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ============ EPC NÁHLED – vždy viditelný ============ -->
            <TextView
                android:id="@+id/tvEpcPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/epc_bg"
                android:fontFamily="monospace"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginBottom="4dp"
                android:text="----–----–----–----–----–----"
                android:textColor="#7FE0FF"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvEpcValid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingBottom="10dp"
                android:text=""
                android:textSize="12sp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Vyjížděcí panel: karty 2–5 -->
    <LinearLayout
        android:id="@+id/workflowSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_bg"
        android:elevation="12dp"
        android:orientation="vertical"
        app:behavior_hideable="false"
        app:behavior_peekHeight="56dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <LinearLayout
            android:id="@+id/workflowSheetHandle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="8dp">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_marginBottom="6dp"
                android:background="#B0BEC5"/>

            <TextView
                android:id="@+id/tvWorkflowSheetTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2–5: EPC, CSV, Heslo, Lock"
                android:textColor="@color/primary_dark"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <include layout="@layout/bottom_sheet_workflow"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
