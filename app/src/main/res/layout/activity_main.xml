<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Hlavička -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/text"
                android:textSize="24sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvReaderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Čtečka: …"
                android:textColor="@color/text_muted"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Výběr akce fyzického tlačítka čtečky -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#E2E6EB"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Spouště čtečky"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipTriggerMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="6dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTriggerEpc"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/trigger_mode_epc"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTriggerPwd"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/trigger_mode_pwd"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTriggerLock"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/trigger_mode_lock"/>
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ KARTA 1: Zdroj dat (TUDU) ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/header1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▾ 1. Zdroj dat – výběr TUDU"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/body1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickSource"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vybrat soubor (.csv / .sql)"/>

                <TextView
                    android:id="@+id/tvSourceFile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp"
                    android:text="Žádný soubor"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="10dp"
                    android:text="TUDU:"
                    android:textColor="@color/text"
                    android:textStyle="bold"/>
                <Spinner
                    android:id="@+id/spTudu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:text="Výhybka:"
                    android:textColor="@color/text"
                    android:textStyle="bold"/>
                <Spinner
                    android:id="@+id/spVyhybka"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvVyhybkaInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="6dp"
                    android:text=""
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ============ EPC NÁHLED – vždy viditelný ============ -->
        <TextView
            android:id="@+id/tvEpcPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/epc_bg"
            android:fontFamily="monospace"
            android:gravity="center"
            android:padding="14dp"
            android:layout_marginBottom="4dp"
            android:text="----–----–----–----–----–----"
            android:textColor="#7FE0FF"
            android:textSize="18sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvEpcValid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="10dp"
            android:text=""
            android:textSize="12sp"/>

        <!-- ============ KARTA 2: Šablona EPC + zápis ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/header2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▾ 2. Šablona EPC a zápis"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/body2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.6" android:text="#" android:textStyle="bold"
                        android:textColor="@color/text_muted" android:textSize="12sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2.4" android:text="Kategorie (název)" android:textStyle="bold"
                        android:textColor="@color/text_muted" android:textSize="12sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2" android:text="Hodnota" android:textStyle="bold"
                        android:textColor="@color/text_muted" android:textSize="12sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1.4" android:text="HEX" android:textStyle="bold"
                        android:gravity="end"
                        android:textColor="@color/text_muted" android:textSize="12sp"/>
                </LinearLayout>

                <include layout="@layout/row_template" android:id="@+id/row1"/>
                <include layout="@layout/row_template" android:id="@+id/row2"/>
                <include layout="@layout/row_template" android:id="@+id/row3"/>
                <include layout="@layout/row_template" android:id="@+id/row4"/>
                <include layout="@layout/row_template" android:id="@+id/row5"/>
                <include layout="@layout/row_template" android:id="@+id/row6"/>
                <include layout="@layout/row_template" android:id="@+id/row7"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#E2E6EB" android:layout_marginTop="12dp"
                    android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Rozhraní zápisu" android:textStyle="bold"
                    android:textColor="@color/text"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:paddingTop="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="bank: EPC"
                        android:textColor="@color/text" android:fontFamily="monospace"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="ptr: 2"
                        android:textColor="@color/text" android:fontFamily="monospace"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Len: 6"
                        android:textColor="@color/text" android:fontFamily="monospace"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:paddingTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Access pwd: " android:textColor="@color/text"/>
                    <EditText android:id="@+id/etAccessPwd"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="00000000"
                        android:fontFamily="monospace" android:maxLength="8"
                        android:inputType="textCapCharacters"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:paddingTop="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Výkon (dBm): " android:textColor="@color/text"/>
                    <EditText android:id="@+id/etPower"
                        android:layout_width="60dp" android:layout_height="wrap_content"
                        android:text="30" android:inputType="number" android:maxLength="2"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnApplyPower"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nastavit"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWrite"
                style="@style/Widget.RfidGo.ActionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/accent"
                android:text="ZAPSAT  (lze i tlačítkem čtečky)"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tvWriteResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text=""
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- ============ KARTA 4: Zaheslování – zápis access pwd ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/header4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▾ 4. Zaheslování – zápis access hesla"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/body4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="bank: RESERVED"
                        android:textColor="@color/text" android:fontFamily="monospace"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="ptr: 2"
                        android:textColor="@color/text" android:fontFamily="monospace"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="len: 2"
                        android:textColor="@color/text" android:fontFamily="monospace"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:paddingTop="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ACCESS PWD: " android:textColor="@color/text"
                        android:textStyle="bold"/>
                    <EditText android:id="@+id/etPwdAccess"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="00000000"
                        android:fontFamily="monospace" android:maxLength="8"
                        android:inputType="textCapCharacters"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:paddingTop="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="NEW PWD: " android:textColor="@color/text"
                        android:textStyle="bold"/>
                    <EditText android:id="@+id/etPwdNew"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:hint="12345678"
                        android:fontFamily="monospace" android:maxLength="8"
                        android:inputType="textCapCharacters"/>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWritePwd"
                style="@style/Widget.RfidGo.ActionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/primary"
                android:text="@string/btn_write_pwd"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tvPwdWriteResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text=""
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- ============ KARTA 5: Zamčení tagu ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/header5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▾ 5. Zamčení tagu"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/body5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="NEW ACCESS PWD: " android:textColor="@color/text"
                        android:textStyle="bold"/>
                    <EditText android:id="@+id/etLockAccessPwd"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="00000000"
                        android:fontFamily="monospace" android:maxLength="8"
                        android:inputType="textCapCharacters"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:paddingTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Lock code: " android:textColor="@color/text"
                        android:textStyle="bold"/>
                    <TextView android:id="@+id/tvLockCode"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/lock_code_value"
                        android:textColor="@color/primary_dark"
                        android:fontFamily="monospace"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLock"
                style="@style/Widget.RfidGo.ActionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/lock"
                android:text="@string/btn_lock"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tvLockResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text=""
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- ============ KARTA 3: Zápis do CSV ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/header3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▾ 3. Tabulka CSV"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/body3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp">

                <CheckBox
                    android:id="@+id/cbAutoCsv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Po zápisu EPC automaticky uložit řádek do CSV"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:paddingTop="4dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExportCsv"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Sdílet / Export"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearCsv"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Vymazat"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCsvPath"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp"
                    android:text=""
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <include layout="@layout/row_csv_header"/>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvCsv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"/>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
